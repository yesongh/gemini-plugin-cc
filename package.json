{
  "name": "@abiswas/gemini-plugin-cc",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Use Gemini CLI from Claude Code to review code or delegate tasks.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.scripts.json",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format .",
    "format:fix": "biome format --fix .",
    "test": "node --test tests/*.test.mjs",
    "ci": "pnpm run build && pnpm run lint && pnpm run test",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/check-version.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
